generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id // Clerk user ID
  email     String   @unique
  createdAt DateTime @default(now())
  audits    Audit[]
}

model Audit {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  company    String
  department String
  teamSize   Int
  tools      String[]
  status     AuditStatus @default(IN_PROGRESS)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  tasks     AuditTask[]
  report    AuditReport?
  workflows Workflow[]
}

model AuditTask {
  id      String @id @default(cuid())
  auditId String
  audit   Audit  @relation(fields: [auditId], references: [id], onDelete: Cascade)
  name    String
  order   Int

  // 6 scoring dimensions (1-3 scale)
  taskVolume      Int // 1=rare, 3=daily
  repeatability   Int // 1=unique, 3=routine
  dataSensitivity Int // 1=highly sensitive, 3=none
  timeCost        Int // 1=minutes, 3=hours
  errorRisk       Int // 1=catastrophic, 3=low
  currentTooling  Int // 1=complex stack, 3=none

  totalScore     Int            // computed: weighted sum
  automationMode AutomationMode
  applicability  Applicability

  workflows Workflow[]
}

model AuditReport {
  id        String   @id @default(cuid())
  auditId   String   @unique
  audit     Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  narrative String   @db.Text
  createdAt DateTime @default(now())
}

model Workflow {
  id        String         @id @default(cuid())
  auditId   String
  audit     Audit          @relation(fields: [auditId], references: [id], onDelete: Cascade)
  taskId    String
  task      AuditTask      @relation(fields: [taskId], references: [id])
  status    WorkflowStatus @default(DRAFT)
  paymentId String?

  trigger    String   @db.Text
  claudeDoes String[]
  humanDoes  String[]
  handoffs   String[]

  timeSavedPerRun Int @default(0) // minutes per run
  runsCount       Int @default(0)

  prompts Prompt[]
  ratings Rating[]

  activatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Prompt {
  id         String   @id @default(cuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  version    Int      @default(1)
  title      String
  content    String   @db.Text
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  ratings Rating[]
}

model Rating {
  id         String   @id @default(cuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  promptId   String?
  prompt     Prompt?  @relation(fields: [promptId], references: [id])
  score      Int // 1-5
  feedback   String?  @db.Text
  createdAt  DateTime @default(now())
}

enum AuditStatus {
  IN_PROGRESS
  COMPLETE
}

enum AutomationMode {
  AUTOMATE
  ASSIST
  SKIP
}

enum Applicability {
  HIGH
  MEDIUM
  LOW
}

enum WorkflowStatus {
  DRAFT
  TESTING
  LIVE
}
