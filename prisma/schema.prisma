generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id // Clerk user ID
  email       String   @unique
  companyName String?
  industry    String?
  tools       String[] // default tools shown in every audit
  onboarded   Boolean  @default(false)
  createdAt   DateTime @default(now())

  audits Audit[]
}

model Audit {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  department String
  teamSize   Int
  tools      String[]    // may override user defaults
  status     AuditStatus @default(IN_PROGRESS)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  tasks     AuditTask[]
  report    AuditReport?
  workflows Workflow[]
}

model AuditTask {
  id      String @id @default(cuid())
  auditId String
  audit   Audit  @relation(fields: [auditId], references: [id], onDelete: Cascade)
  name    String
  order   Int

  taskVolume      Int
  repeatability   Int
  dataSensitivity Int
  timeCost        Int
  errorRisk       Int
  currentTooling  Int

  totalScore     Int
  automationMode AutomationMode
  applicability  Applicability

  chatContext String? @db.Text // JSON-encoded scoring conversation messages

  workflows Workflow[]
}

model AuditReport {
  id        String   @id @default(cuid())
  auditId   String   @unique
  audit     Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  narrative String   @db.Text
  createdAt DateTime @default(now())
}

model Workflow {
  id      String         @id @default(cuid())
  auditId String
  audit   Audit          @relation(fields: [auditId], references: [id], onDelete: Cascade)
  taskId  String
  task    AuditTask      @relation(fields: [taskId], references: [id])
  status  WorkflowStatus @default(DRAFT)

  summary         String? @db.Text // one-line: what this workflow does
  timeSavedPerRun Int     @default(0)
  runsCount       Int     @default(0)

  steps   WorkflowStep[]
  ratings WorkflowRating[]

  activatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model WorkflowStep {
  id         String   @id @default(cuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  order      Int
  type       StepType
  tool       String?  // e.g. "Zendesk" — from audit tools list
  title      String
  description String  @db.Text

  // AI steps only
  prompt        String? @db.Text
  promptVersion Int     @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ratings StepRating[]
}

model WorkflowRating {
  id         String   @id @default(cuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  score      Int      // 1-5
  feedback   String?  @db.Text
  createdAt  DateTime @default(now())
}

model StepRating {
  id       String       @id @default(cuid())
  stepId   String
  step     WorkflowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  score    Int          // 1-5
  feedback String?      @db.Text
  createdAt DateTime    @default(now())
}

enum AuditStatus {
  IN_PROGRESS
  COMPLETE
}

enum AutomationMode {
  AUTOMATE
  ASSIST
  SKIP
}

enum Applicability {
  HIGH
  MEDIUM
  LOW
}

enum WorkflowStatus {
  DRAFT
  TESTING
  LIVE
}

enum StepType {
  TRIGGER
  AI
  HUMAN
  INTEGRATION
  OUTPUT
}
